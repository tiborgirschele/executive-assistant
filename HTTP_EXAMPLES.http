@host = http://localhost:8090
@token = replace_with_token_or_leave_blank
@principal_id = exec-1
@session_id = replace_me
@artifact_id = replace_me
@receipt_id = replace_me
@cost_id = replace_me
@delivery_id = replace_me
@approval_id = replace_me
@memory_candidate_id = replace_me
@memory_item_id = replace_me
@entity_id = replace_me
@relationship_id = replace_me
@commitment_id = replace_me
@authority_binding_id = replace_me
@delivery_preference_id = replace_me
@follow_up_id = replace_me
@interruption_budget_id = replace_me
@oversized_text = replace_with_20001_chars

### Principal-scoped connector and memory routes
### Use X-EA-Principal-ID to set the effective principal.
### body/query principal_id values below are compatibility filters only and mismatches return 403 principal_scope_mismatch.

### Health
GET {{host}}/health

### Liveness
GET {{host}}/health/live

### Readiness
GET {{host}}/health/ready

### Version
GET {{host}}/version

### Rewrite -> artifact + execution session
POST {{host}}/v1/rewrite/artifact
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "text": "Prepare a concise follow-up draft."
}

### Rewrite -> fetch session
GET {{host}}/v1/rewrite/sessions/{{session_id}}

### Rewrite -> fetch artifact
GET {{host}}/v1/rewrite/artifacts/{{artifact_id}}

### Rewrite -> fetch receipt
GET {{host}}/v1/rewrite/receipts/{{receipt_id}}

### Rewrite -> fetch run cost
GET {{host}}/v1/rewrite/run-costs/{{cost_id}}

### Rewrite -> blocked policy (expected 403)
POST {{host}}/v1/rewrite/artifact
Content-Type: application/json

{
  "text": "{{oversized_text}}"
}

### Policy audit -> recent decisions
GET {{host}}/v1/policy/decisions/recent?limit=20

### Policy audit -> by session
GET {{host}}/v1/policy/decisions/recent?session_id={{session_id}}&limit=20

### Policy -> evaluate external-send approval
POST {{host}}/v1/policy/evaluate
Content-Type: application/json

{
  "content": "Send the board update to the distribution list.",
  "tool_name": "connector.dispatch",
  "action_kind": "delivery.send",
  "channel": "email"
}

### Approvals -> pending
GET {{host}}/v1/policy/approvals/pending?limit=20

### Approvals -> history
GET {{host}}/v1/policy/approvals/history?limit=20

### Approvals -> approve and resume execution
POST {{host}}/v1/policy/approvals/{{approval_id}}/approve
Content-Type: application/json

{
  "decided_by": "operator",
  "reason": "approved for execution"
}

### Approvals -> deny
POST {{host}}/v1/policy/approvals/{{approval_id}}/deny
Content-Type: application/json

{
  "decided_by": "operator",
  "reason": "deny in smoke"
}

### Approvals -> expire
POST {{host}}/v1/policy/approvals/{{approval_id}}/expire
Content-Type: application/json

{
  "decided_by": "operator",
  "reason": "manual expiry"
}

### Observations -> ingest
POST {{host}}/v1/observations/ingest
Content-Type: application/json

{
  "principal_id": "exec-1",
  "channel": "email",
  "event_type": "thread.opened",
  "source_id": "gmail:exec-1",
  "external_id": "msg-42",
  "dedupe_key": "gmail:exec-1:msg-42",
  "auth_context_json": {
    "scope": "mail.readonly"
  },
  "raw_payload_uri": "s3://ea-observations/raw/msg-42.json",
  "payload": {
    "subject": "Board prep",
    "from": "ceo@example.com"
  }
}

### Observations -> recent
GET {{host}}/v1/observations/recent?limit=20

### Delivery outbox -> enqueue
POST {{host}}/v1/delivery/outbox
Content-Type: application/json

{
  "channel": "slack",
  "recipient": "U12345",
  "content": "Draft prepared and queued for review.",
  "idempotency_key": "delivery-slack-u12345-thread-1",
  "metadata": {
    "priority": "high",
    "thread": "T-1"
  }
}

### Delivery outbox -> pending
GET {{host}}/v1/delivery/outbox/pending?limit=20

### Delivery outbox -> mark sent
POST {{host}}/v1/delivery/outbox/{{delivery_id}}/sent

### Delivery outbox -> mark failed (retry)
POST {{host}}/v1/delivery/outbox/{{delivery_id}}/failed
Content-Type: application/json

{
  "error": "temporary send failure",
  "retry_in_seconds": 60,
  "dead_letter": false
}

### Delivery outbox -> mark sent unknown id (expected 404)
POST {{host}}/v1/delivery/outbox/not-a-real-id/sent

### Telegram channel adapter -> ingest
POST {{host}}/v1/channels/telegram/ingest
Content-Type: application/json

{
  "update": {
    "message": {
      "chat": { "id": 42 },
      "message_id": 7,
      "date": 1234567890,
      "text": "hello from telegram"
    }
  }
}

### Rewrite -> unknown session (expected 404)
GET {{host}}/v1/rewrite/sessions/not-a-real-session-id

### Tools -> upsert registry entry
POST {{host}}/v1/tools/registry
Content-Type: application/json

{
  "tool_name": "email.send",
  "version": "v1",
  "input_schema_json": {
    "type": "object"
  },
  "output_schema_json": {
    "type": "object"
  },
  "policy_json": {
    "risk": "medium"
  },
  "allowed_channels": [
    "email",
    "slack"
  ],
  "approval_default": "manager",
  "enabled": true
}

### Tools -> list enabled
GET {{host}}/v1/tools/registry?limit=20

### Tools -> get by name
GET {{host}}/v1/tools/registry/email.send

### Connectors -> upsert binding
POST {{host}}/v1/connectors/bindings
Content-Type: application/json
X-EA-Principal-ID: {{principal_id}}

{
  "connector_name": "gmail",
  "external_account_ref": "acct-1",
  "scope_json": {
    "scopes": [
      "mail.readonly"
    ]
  },
  "auth_metadata_json": {
    "provider": "google"
  },
  "status": "enabled"
}

### Connectors -> list by principal
GET {{host}}/v1/connectors/bindings?limit=20
X-EA-Principal-ID: {{principal_id}}

### Connectors -> principal mismatch (expected 403)
GET {{host}}/v1/connectors/bindings?principal_id=exec-2&limit=20
X-EA-Principal-ID: {{principal_id}}

### Connectors -> set status
POST {{host}}/v1/connectors/bindings/replace_with_binding_id/status
Content-Type: application/json

{
  "status": "disabled"
}

### Task Contracts -> upsert
POST {{host}}/v1/tasks/contracts
Content-Type: application/json

{
  "task_key": "rewrite_text",
  "deliverable_type": "rewrite_note",
  "default_risk_class": "low",
  "default_approval_class": "none",
  "allowed_tools": [
    "artifact_repository"
  ],
  "evidence_requirements": [],
  "memory_write_policy": "reviewed_only",
  "budget_policy_json": {
    "class": "low"
  }
}

### Task Contracts -> list
GET {{host}}/v1/tasks/contracts?limit=20

### Task Contracts -> get by key
GET {{host}}/v1/tasks/contracts/rewrite_text

### Plans -> compile from task contract
POST {{host}}/v1/plans/compile
Content-Type: application/json

{
  "task_key": "rewrite_text",
  "principal_id": "exec-1",
  "goal": "rewrite this text for board notes"
}

### Memory -> stage candidate
POST {{host}}/v1/memory/candidates
Content-Type: application/json
X-EA-Principal-ID: {{principal_id}}

{
  "category": "stakeholder_pref",
  "summary": "CEO prefers concise updates",
  "fact_json": {
    "tone": "concise"
  },
  "source_session_id": "session-1",
  "source_event_id": "event-1",
  "source_step_id": "step-1",
  "confidence": 0.72,
  "sensitivity": "internal"
}

### Memory -> list candidates
GET {{host}}/v1/memory/candidates?limit=20&status=pending

### Memory -> promote candidate
POST {{host}}/v1/memory/candidates/{{memory_candidate_id}}/promote
Content-Type: application/json

{
  "reviewer": "operator",
  "sharing_policy": "private"
}

### Memory -> reject candidate
POST {{host}}/v1/memory/candidates/{{memory_candidate_id}}/reject
Content-Type: application/json

{
  "reviewer": "operator"
}

### Memory -> list items
GET {{host}}/v1/memory/items?limit=20
X-EA-Principal-ID: {{principal_id}}

### Memory -> principal mismatch (expected 403)
GET {{host}}/v1/memory/items?limit=20&principal_id=exec-2
X-EA-Principal-ID: {{principal_id}}

### Memory -> get item
GET {{host}}/v1/memory/items/{{memory_item_id}}

### Memory -> upsert entity
POST {{host}}/v1/memory/entities
Content-Type: application/json

{
  "principal_id": "exec-1",
  "entity_type": "person",
  "canonical_name": "Alex Executive",
  "attributes_json": {
    "role": "executive"
  },
  "confidence": 0.9,
  "status": "active"
}

### Memory -> list entities
GET {{host}}/v1/memory/entities?limit=20&principal_id=exec-1

### Memory -> get entity
GET {{host}}/v1/memory/entities/{{entity_id}}

### Memory -> upsert relationship
POST {{host}}/v1/memory/relationships
Content-Type: application/json

{
  "principal_id": "exec-1",
  "from_entity_id": "replace_entity_a",
  "to_entity_id": "replace_entity_b",
  "relationship_type": "reports_to",
  "attributes_json": {
    "strength": "high"
  },
  "confidence": 0.75
}

### Memory -> list relationships
GET {{host}}/v1/memory/relationships?limit=20&principal_id=exec-1

### Memory -> get relationship
GET {{host}}/v1/memory/relationships/{{relationship_id}}

