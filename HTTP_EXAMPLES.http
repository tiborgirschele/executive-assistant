@host = http://localhost:8090
@token = replace_with_token_or_leave_blank
@principal_id = exec-1
@session_id = replace_me
@artifact_id = replace_me
@receipt_id = replace_me
@cost_id = replace_me
@delivery_id = replace_me
@approval_id = replace_me
@step_id = replace_me
@human_task_id = replace_me
@memory_candidate_id = replace_me
@memory_item_id = replace_me
@entity_id = replace_me
@relationship_id = replace_me
@commitment_id = replace_me
@authority_binding_id = replace_me
@delivery_preference_id = replace_me
@follow_up_id = replace_me
@interruption_budget_id = replace_me
@oversized_text = replace_with_20001_chars

### Principal-scoped rewrite/session/plan, connector, human-task, and memory routes
### Use X-EA-Principal-ID to set the effective principal.
### body/query principal_id values below are compatibility filters only and mismatches return 403 principal_scope_mismatch.

### Health
GET {{host}}/health

### Liveness
GET {{host}}/health/live

### Readiness
GET {{host}}/health/ready

### Version
GET {{host}}/version

### Rewrite -> artifact + execution session
POST {{host}}/v1/rewrite/artifact
Content-Type: application/json
Authorization: Bearer {{token}}
X-EA-Principal-ID: {{principal_id}}

{
  "text": "Prepare a concise follow-up draft."
}

### Rewrite -> fetch session
GET {{host}}/v1/rewrite/sessions/{{session_id}}
X-EA-Principal-ID: {{principal_id}}

### Rewrite -> fetch session filtered to one human-task assignment source
GET {{host}}/v1/rewrite/sessions/{{session_id}}?human_task_assignment_source=manual
X-EA-Principal-ID: {{principal_id}}

### Rewrite -> fetch session filtered to current ownerless human-task rows
GET {{host}}/v1/rewrite/sessions/{{session_id}}?human_task_assignment_source=none
X-EA-Principal-ID: {{principal_id}}

### Rewrite -> fetch artifact (includes originating task_key and deliverable_type)
GET {{host}}/v1/rewrite/artifacts/{{artifact_id}}
X-EA-Principal-ID: {{principal_id}}

### Rewrite -> fetch receipt
GET {{host}}/v1/rewrite/receipts/{{receipt_id}}
X-EA-Principal-ID: {{principal_id}}

### Rewrite -> fetch run cost
GET {{host}}/v1/rewrite/run-costs/{{cost_id}}
X-EA-Principal-ID: {{principal_id}}

### Rewrite -> body principal mismatch (expected 403 principal_scope_mismatch)
POST {{host}}/v1/rewrite/artifact
Content-Type: application/json
Authorization: Bearer {{token}}
X-EA-Principal-ID: {{principal_id}}

{
  "text": "This should stay inside one principal scope.",
  "principal_id": "exec-2"
}

### Rewrite -> blocked policy (expected 403)
POST {{host}}/v1/rewrite/artifact
Content-Type: application/json

{
  "text": "{{oversized_text}}"
}

### Policy audit -> recent decisions
GET {{host}}/v1/policy/decisions/recent?limit=20

### Policy audit -> by session
GET {{host}}/v1/policy/decisions/recent?session_id={{session_id}}&limit=20

### Policy -> evaluate external-send approval
POST {{host}}/v1/policy/evaluate
Content-Type: application/json

{
  "content": "Send the board update to the distribution list.",
  "tool_name": "connector.dispatch",
  "action_kind": "delivery.send",
  "channel": "email"
}

### Approvals -> pending
GET {{host}}/v1/policy/approvals/pending?limit=20

### Approvals -> history
GET {{host}}/v1/policy/approvals/history?limit=20

### Approvals -> approve and resume execution
POST {{host}}/v1/policy/approvals/{{approval_id}}/approve
Content-Type: application/json

{
  "decided_by": "operator",
  "reason": "approved for execution"
}

### Approvals -> deny
POST {{host}}/v1/policy/approvals/{{approval_id}}/deny
Content-Type: application/json

{
  "decided_by": "operator",
  "reason": "deny in smoke"
}

### Approvals -> expire
POST {{host}}/v1/policy/approvals/{{approval_id}}/expire
Content-Type: application/json

{
  "decided_by": "operator",
  "reason": "manual expiry"
}

### Human tasks -> create linked review packet
POST {{host}}/v1/human/tasks
Content-Type: application/json
X-EA-Principal-ID: {{principal_id}}

{
  "session_id": "{{session_id}}",
  "step_id": "{{step_id}}",
  "task_type": "communications_review",
  "role_required": "communications_reviewer",
  "brief": "Review the draft before external send.",
  "input_json": {
    "artifact_id": "{{artifact_id}}"
  },
  "desired_output_json": {
    "format": "review_packet"
  },
  "priority": "high",
  "resume_session_on_return": true
}

### Human tasks -> list for principal / role backlog
GET {{host}}/v1/human/tasks?principal_id={{principal_id}}&role_required=communications_reviewer&overdue_only=true&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> list for assigned operator
GET {{host}}/v1/human/tasks?principal_id={{principal_id}}&assigned_operator_id=operator&status=claimed&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> list for one session and one assignment source
GET {{host}}/v1/human/tasks?principal_id={{principal_id}}&session_id={{session_id}}&assignment_source=manual&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog sorted by latest ownership churn
GET {{host}}/v1/human/tasks/backlog?sort=last_transition_desc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog sorted by oldest created task first
GET {{host}}/v1/human/tasks/backlog?sort=created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog sorted by priority band, then oldest created task first
GET {{host}}/v1/human/tasks/backlog?sort=priority_desc_created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog filtered to high-priority work
GET {{host}}/v1/human/tasks/backlog?priority=high&sort=created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog filtered to urgent and high work together
GET {{host}}/v1/human/tasks/backlog?priority=urgent,high&sort=priority_desc_created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog filtered to planner auto-preselected work
GET {{host}}/v1/human/tasks/backlog?assignment_source=auto_preselected&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> priority summary for a reviewer queue
GET {{host}}/v1/human/tasks/priority-summary?status=pending&role_required=communications_reviewer
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> priority summary for an exact operator-profile match queue
GET {{host}}/v1/human/tasks/priority-summary?status=pending&assignment_state=unassigned&operator_id=operator-specialist
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> priority summary for one assigned reviewer queue
GET {{host}}/v1/human/tasks/priority-summary?status=pending&role_required=communications_reviewer&assigned_operator_id=operator
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> priority summary for one pending assignment source
GET {{host}}/v1/human/tasks/priority-summary?status=pending&assignment_source=manual
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless pending priority summary
GET {{host}}/v1/human/tasks/priority-summary?status=pending&assignment_state=unassigned&assignment_source=none
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog sorted by earliest SLA
GET {{host}}/v1/human/tasks/backlog?sort=sla_due_at_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog sorted by earliest SLA, then latest ownership churn
GET {{host}}/v1/human/tasks/backlog?sort=sla_due_at_asc_last_transition_desc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> general list sorted by earliest SLA, with no-SLA work falling back to oldest-created
GET {{host}}/v1/human/tasks?principal_id={{principal_id}}&status=pending&sort=sla_due_at_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct pending backlog
GET {{host}}/v1/human/tasks/backlog?role_required=communications_reviewer&overdue_only=true&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct unassigned pending backlog
GET {{host}}/v1/human/tasks/unassigned?role_required=communications_reviewer&overdue_only=true&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless unassigned pending backlog
GET {{host}}/v1/human/tasks/unassigned?assignment_source=none&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless slice through the general pending backlog
GET {{host}}/v1/human/tasks/backlog?assignment_state=unassigned&assignment_source=none&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless backlog oldest-first
GET {{host}}/v1/human/tasks/backlog?assignment_state=unassigned&assignment_source=none&sort=created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless backlog newest-first by transition time
GET {{host}}/v1/human/tasks/backlog?assignment_state=unassigned&assignment_source=none&sort=last_transition_desc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless unassigned queue oldest-first
GET {{host}}/v1/human/tasks/unassigned?assignment_source=none&sort=created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless unassigned queue newest-first by transition time
GET {{host}}/v1/human/tasks/unassigned?assignment_source=none&sort=last_transition_desc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless pending list oldest-first
GET {{host}}/v1/human/tasks?status=pending&assignment_state=unassigned&assignment_source=none&sort=created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> ownerless pending list newest-first by transition time
GET {{host}}/v1/human/tasks?status=pending&assignment_state=unassigned&assignment_source=none&sort=last_transition_desc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> session-scoped ownerless queue oldest-first
GET {{host}}/v1/human/tasks?session_id={{session_id}}&assignment_source=none&sort=created_asc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> session-scoped ownerless queue newest-first by transition time
GET {{host}}/v1/human/tasks?session_id={{session_id}}&assignment_source=none&sort=last_transition_desc&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> direct operator queue
GET {{host}}/v1/human/tasks/mine?operator_id=operator&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> assign operator while task remains pending
POST {{host}}/v1/human/tasks/{{human_task_id}}/assign
Content-Type: application/json
X-EA-Principal-ID: {{principal_id}}

{
  "operator_id": "operator"
}

### Human tasks -> assignment history
GET {{host}}/v1/human/tasks/{{human_task_id}}/assignment-history?limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> filtered assignment history
GET {{host}}/v1/human/tasks/{{human_task_id}}/assignment-history?limit=20&event_name=human_task_assigned&assigned_by_actor_id={{principal_id}}
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> assignment history filtered by assignment source
GET {{host}}/v1/human/tasks/{{human_task_id}}/assignment-history?limit=20&assignment_source=recommended
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> assignment history filtered to ownerless creation transitions
GET {{host}}/v1/human/tasks/{{human_task_id}}/assignment-history?limit=20&assignment_source=none
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> assigned-only pending backlog
GET {{host}}/v1/human/tasks/backlog?role_required=communications_reviewer&overdue_only=true&assignment_state=assigned&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> any claimed packets
GET {{host}}/v1/human/tasks?principal_id={{principal_id}}&assignment_state=claimed&limit=20
X-EA-Principal-ID: {{principal_id}}

### Human tasks -> claim
POST {{host}}/v1/human/tasks/{{human_task_id}}/claim
Content-Type: application/json
X-EA-Principal-ID: {{principal_id}}

{
  "operator_id": "operator"
}

### Human tasks -> return structured review packet
POST {{host}}/v1/human/tasks/{{human_task_id}}/return
Content-Type: application/json
X-EA-Principal-ID: {{principal_id}}

{
  "operator_id": "operator",
  "resolution": "ready_for_send",
  "returned_payload_json": {
    "summary": "Reviewed and ready."
  },
  "provenance_json": {
    "review_mode": "human"
  }
}

