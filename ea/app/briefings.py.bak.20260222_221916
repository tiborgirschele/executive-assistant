from __future__ import annotations
import re, json
from datetime import datetime, timezone
from app.audit import log_event
from app.config import TenantConfig
from app import gog
from app.llm import call_llm

def _safe_truncate(s: str, n: int = 6000) -> str:
    return s if len(s) <= n else s[:n] + "\n...[truncated]"

async def build_briefing_for_tenant(tenant: TenantConfig) -> dict:
    # Collect deterministic raw data
    parts = []
    parts.append(f"DATE_UTC={datetime.now(timezone.utc).isoformat()}")

    parts.append("\n## EMAIL_INBOX_24H (SELF)\n" + _safe_truncate(gog.gmail_recent_summary(tenant.openclaw_container, 24)))
    parts.append("\n## EMAIL_SENT_7D (SELF)\n" + _safe_truncate(gog.gmail_sent_followups(tenant.openclaw_container, 7)))
    parts.append("\n## CALENDAR_7D (SELF)\n" + _safe_truncate(gog.calendar_upcoming(tenant.openclaw_container, 7)))

    if tenant.tasks_enabled:
        parts.append("\n## TASKS (SELF)\n" + _safe_truncate(gog.tasks_list(tenant.openclaw_container, tenant.tasklist_id)))

    if tenant.include_family and tenant.family_openclaw_container:
        parts.append("\n## EMAIL_INBOX_24H (FAMILY)\n" + _safe_truncate(gog.gmail_recent_summary(tenant.family_openclaw_container, 24)))
        parts.append("\n## CALENDAR_7D (FAMILY)\n" + _safe_truncate(gog.calendar_upcoming(tenant.family_openclaw_container, 7)))
        # We intentionally do NOT include Liz's personal in Tibor tenant because tenant.openclaw_container defines self.

    raw = "\n".join(parts)
    log_event(tenant.key,"briefing","raw_collected","raw inputs collected",{"bytes":len(raw)})

    # Produce final CEO-style output + poll options as JSON
    prompt = f"""You are an evidence-based executive assistant.
You will receive raw tool outputs (email search summaries, calendar, tasks).
Do NOT invent facts. If evidence is missing, say "STATUS UNBEKANNT – BITTE MANUELL PRÜFEN".

Return ONLY a valid JSON object with keys:
- text: string (Telegram Markdown allowed; keep concise; include actionable links if present)
- options: array of up to 5 strings (short poll options; include emojis; should be actionable)
Rules:
- Focus only on the tenant "{tenant.label}" (plus FAMILY if included in raw).
- Exclude unrelated accounts.
- No whining about tool failures; simply mark as STATUS UNBEKANNT.
- Add a small "DEEP DIVE MENU" line: "Reply: Detail 1 / Detail 2 ..." using numbered actions.

RAW:
{raw}
"""
    out = await call_llm(prompt, temperature=0.0)
    # Extract JSON
    m = re.search(r"\{[\s\S]*\}", out)
    if not m:
        log_event(tenant.key,"briefing","error","LLM did not return JSON",{"out":out[:2000]})
        return {"text":"STATUSBOARD: (LLM JSON error)","options":["🔁 Retry","📌 Show logs"]}
    try:
        obj = json.loads(m.group(0))
    except Exception as e:
        log_event(tenant.key,"briefing","error","JSON parse failed",{"err":str(e),"out":out[:2000]})
        return {"text":"STATUSBOARD: (JSON parse error)","options":["🔁 Retry","📌 Show logs"]}
    # Normalize
    text = str(obj.get("text","")).strip()
    options = obj.get("options") or []
    options = [str(x)[:60] for x in options if str(x).strip()]
    return {"text": text, "options": options[:5], "raw": raw}
