from __future__ import annotations

import json
import re
from typing import Any, Dict, Tuple

from app.config import TenantConfig
from app.gog import (
    gog_calendar_upcoming,
    gog_gmail_search,
    gog_tasks_list,
    gog_tasks_list_lists,
)
from app.llm import call_llm
from app.audit import log_event
from app.db import shopping_list_get, whatsapp_recent


def _safe_json_extract(text: str) -> Dict[str, Any]:
    if not text:
        return {"text": "(empty)", "options": ["🔁 Retry", "📌 Logs"]}

    m = re.search(r"\{[\s\S]*\}", text)
    if not m:
        return {"text": text.strip()[:3500], "options": ["🔁 Retry", "📌 Logs"]}

    try:
        obj = json.loads(m.group(0))
        if not isinstance(obj, dict):
            raise ValueError("not an object")
        obj.setdefault("text", text.strip()[:3500])
        obj.setdefault("options", ["🔁 Retry", "📌 Logs"])
        if not isinstance(obj.get("options"), list):
            obj["options"] = ["🔁 Retry", "📌 Logs"]
        obj["options"] = [str(x)[:90] for x in obj["options"]][:8]
        obj["text"] = str(obj["text"])[:3500]
        return obj
    except Exception:
        return {"text": text.strip()[:3500], "options": ["🔁 Retry", "📌 Logs"]}


async def _tasks_block(tc: TenantConfig) -> str:
    if not tc.tasks_enabled:
        return "(disabled)"
    try:
        lists = await gog_tasks_list_lists(tc.openclaw_container)
        if tc.tasklist_id:
            tasks = await gog_tasks_list(tc.openclaw_container, tc.tasklist_id)
            return f"Tasklists:\n{lists}\n\nTasks:\n{tasks}"
        return f"Tasklists:\n{lists}"
    except Exception as e:
        log_event("briefing.tasks.error", str(e), tenant=tc.key)
        return f"(tasks error: {e})"


async def _family_block(tc: TenantConfig) -> Tuple[str, str]:
    if not tc.include_family or not tc.family_openclaw_container:
        return "", ""
    try:
        fam_inbox = await gog_gmail_search(tc.family_openclaw_container, "newer_than:2d", limit=30)
    except Exception as e:
        fam_inbox = f"(family inbox error: {e})"
    try:
        fam_cal = await gog_calendar_upcoming(tc.family_openclaw_container, days=14)
    except Exception as e:
        fam_cal = f"(family calendar error: {e})"
    return fam_inbox, fam_cal


async def build_briefing_for_tenant(tc: TenantConfig) -> Dict[str, Any]:
    try:
        inbox = await gog_gmail_search(tc.openclaw_container, "in:inbox newer_than:2d", limit=40)
    except Exception as e:
        inbox = f"(inbox error: {e})"

    try:
        sent = await gog_gmail_search(tc.openclaw_container, "in:sent newer_than:7d", limit=40)
    except Exception as e:
        sent = f"(sent error: {e})"

    try:
        cal = await gog_calendar_upcoming(tc.openclaw_container, days=14)
    except Exception as e:
        cal = f"(calendar error: {e})"

    tasks = await _tasks_block(tc)
    fam_inbox, fam_cal = await _family_block(tc)

    wa_block = ""
    if tc.whatsapp_memory_enabled:
        try:
            msgs = whatsapp_recent(tc.key, limit=30, since_hours=24 * 14)
            if msgs:
                lines = []
                for m in msgs:
                    ts = str(m.get("ts"))
                    direction = m.get("direction")
                    peer = m.get("peer") or ""
                    text = (m.get("text") or "").replace("\n", " ").strip()
                    lines.append(f"- {ts} [{direction}] {peer}: {text}")
                wa_block = "\n".join(lines)
            else:
                wa_block = "(no whatsapp memory in db)"
        except Exception as e:
            wa_block = f"(whatsapp memory error: {e})"

    shop_block = ""
    try:
        items = shopping_list_get(tc.key)
        if items:
            shop_lines = []
            for it in items:
                chk = "✅" if it.get("checked") else "⬜"
                shop_lines.append(f"{chk} {it.get('item')}")
            shop_block = "\n".join(shop_lines)
    except Exception:
        shop_block = ""

    prompt = f"""You are an Executive Assistant OS.

TENANT
- key: {tc.key}
- label: {tc.label}

DATA (raw; may contain noise)
[EMAIL_INBOX]
{inbox}

[EMAIL_SENT]
{sent}

[CALENDAR_NEXT_14D]
{cal}

[GOOGLE_TASKS]
{tasks}

[FAMILY_INBOX_2D] (only if family is enabled)
{fam_inbox}

[FAMILY_CALENDAR_14D] (only if family is enabled)
{fam_cal}

[WHATSAPP_LAST_14D] (if enabled)
{wa_block}

[SHOPPING_LIST] (if available)
{shop_block}

OUTPUT RULES
- Produce a briefing addressed to {tc.label}.
- Do NOT mention other tenants' private inboxes.
- Extract ACTIONS with clear next steps.
- Evidence: if you claim something about money/refunds/delivery, mark as 'NEEDS CHECK' unless supported by data.
- Keep it short. Bullet points only. No fluff.

POLL RULES
- Provide up to 6 poll options (strings), each <= 90 chars.
- Options MUST start with one of:
  - "🔍" for "Deep dive" on an item (will trigger an investigation)
  - "✅" to acknowledge/mark something as done
  - "☕" for preference / household signal (e.g., coffee/bread)
  - "🔁 Retry"
  - "📌 Logs"

Return ONLY valid JSON: {{"text":"...","options":["..."]}}.
"""

    raw = await call_llm(prompt)
    obj = _safe_json_extract(raw)

    opts = obj.get("options") or []
    if "🔁 Retry" not in opts:
        opts.append("🔁 Retry")
    if "📌 Logs" not in opts:
        opts.append("📌 Logs")
    obj["options"] = opts[:8]

    log_event("briefing.built", f"tenant={tc.key} opts={obj['options']}", tenant=tc.key)
    return obj
